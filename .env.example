# Copy to `.env.local` for local dev. On Vercel, set these in Project → Settings → Environment Variables.
# For a full product demo video, enable the three FLAG_* lines and (optionally) ALLOW_DEMO_BILLING — see CLAUDE.md §10 Demo.

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App URL: use the exact origin viewers will use (local or Vercel preview/production).
# Also add this URL to Supabase → Authentication → URL Configuration → Site URL and Redirect URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Feature flags (turn ON for demo recordings) ---
NEXT_PUBLIC_FLAG_COMPANIES_ENABLED=true
NEXT_PUBLIC_FLAG_RECEIPTS_ENABLED=true
NEXT_PUBLIC_FLAG_EXPORTS_ENABLED=true
NEXT_PUBLIC_FLAG_PUBLIC_PROFILE_ENABLED=true

# --- Demo: skip real Stripe (owner/admin only; set false or unset for production) ---
ALLOW_DEMO_BILLING=true

# --- Stripe (real checkout; optional if using ALLOW_DEMO_BILLING for tier) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_PRICE_SME_TAX=price_...
# STRIPE_PRICE_SME_PLUS=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# --- Email (required for company invite + verification mails; receipts) ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# --- SudReg (Croatian court registry) for company OIB verification ---
# Register a free account at https://sudreg-data.gov.hr (test) /
# https://sudreg-data.gov.hr (prod) and paste the issued credentials.
# The trailing two dots are part of the value, not punctuation.
# SUDREG_CLIENT_ID=
# SUDREG_CLIENT_SECRET=
# SUDREG_API_URL=https://sudreg-data.gov.hr

# --- Other ---
# OIB_LOOKUP_URL=
# DEDUCTION_CEILING_PCT=2.0
# AUTO_ACKNOWLEDGE_DAYS=14
# CRON_SECRET=
